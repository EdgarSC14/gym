---
import Layout from "./Layout.astro"; const { title } = Astro.props;
---
<Layout title={`${title} - Fit 360`} admin><div class="admin-container"><nav class="admin-sidebar"><div class="logo">Fit <span>360</span></div><ul><li><a href="/admin"><i class="bx bxs-dashboard"></i><span>Dashboard</span></a></li><li><a href="/admin/users"><i class="bx bxs-user-detail"></i><span>Usuarios</span></a></li><li><a href="/admin/products"><i class="bx bxs-shopping-bag"></i><span>Productos</span></a></li><li><a href="/admin/services"><i class="bx bxs-dumbbell"></i><span>Servicios</span></a></li><li><a href="/admin/plans"><i class="bx bxs-credit-card"></i><span>Suscripciones</span></a></li><li><a href="/admin/suppliers"><i class="bx bxs-truck"></i><span>Proveedores</span></a></li><li><a href="/admin/inventory"><i class="bx bxs-package"></i><span>Inventario</span></a></li><li><a href="/admin/audit"><i class="bx bxs-book"></i><span>Auditoría</span></a></li><li><a href="/admin/media"><i class="bx bxs-image"></i><span>Multimedia</span></a></li><li><a href="/admin/sales"><i class="bx bxs-chart"></i><span>Estadísticas</span></a></li><li><a href="/"><i class="bx bx-home"></i><span>Ver sitio</span></a></li></ul></nav><main class="admin-main"><header class="admin-header"><h1>{title}</h1><span>{Astro.locals.user?.username}</span></header><slot /></main></div><script is:inline src="/admin-script.js"></script></Layout>
