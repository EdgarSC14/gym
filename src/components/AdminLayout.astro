---
import Layout from "./Layout.astro";
const { title } = Astro.props;
const path = Astro.url.pathname;
const navItems = [
  { href: "/admin", label: "Dashboard", icon: "bx bxs-dashboard" },
  { href: "/admin/users", label: "Usuarios", icon: "bx bxs-user-detail" },
  { href: "/admin/products", label: "Productos", icon: "bx bxs-shopping-bag" },
  { href: "/admin/services", label: "Servicios", icon: "bx bxs-dumbbell" },
  { href: "/admin/plans", label: "Suscripciones", icon: "bx bxs-credit-card" },
  { href: "/admin/suppliers", label: "Proveedores", icon: "bx bxs-truck" },
  { href: "/admin/inventory", label: "Inventario", icon: "bx bxs-package" },
  { href: "/admin/media", label: "Multimedia", icon: "bx bxs-image" },
  { href: "/admin/audit", label: "Auditoría", icon: "bx bxs-book" },
  { href: "/admin/sales", label: "Estadísticas", icon: "bx bxs-chart" },
];
const isActive = (href: string) => href === "/admin" ? path === href : path.startsWith(href);
const username = Astro.locals.user?.username || "Admin";
const initial = username.slice(0, 1).toUpperCase();
---
<Layout title={`${title} - Fit 360`} admin>
  <button class="menu-toggle" type="button" aria-label="Abrir menú"><i class="bx bx-menu"></i></button>
  <div class="admin-container">
    <nav class="admin-sidebar" aria-label="Administración Fit 360">
      <a href="/admin" class="admin-brand" aria-label="Dashboard Fit 360">
        <span class="admin-brand-mark">360</span>
        <span><strong>Fit 360</strong><small>Control</small></span>
      </a>
      <ul>
        {navItems.map((item) => (
          <li>
            <a href={item.href} class={isActive(item.href) ? "active" : ""} aria-current={isActive(item.href) ? "page" : undefined}>
              <i class={item.icon}></i><span>{item.label}</span>
            </a>
          </li>
        ))}
      </ul>
      <a class="admin-site-link" href="/"><i class="bx bx-home"></i><span>Ver sitio</span></a>
    </nav>
    <main class="admin-main">
      <header class="admin-header">
        <div>
          <p class="admin-kicker">Fit 360 admin</p>
          <h1>{title}</h1>
        </div>
        <div class="admin-user-pill" title={username}>
          <span>{initial}</span>
          <strong>{username}</strong>
        </div>
      </header>
      <slot />
    </main>
  </div>
  <script is:inline src="/admin-script.js"></script>
</Layout>
