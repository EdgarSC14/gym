---
const user = Astro.locals.user;
---
<header>
  <a href="/#home" class="logo">Fit <span>360</span></a>
  <div class="bx bx-menu" id="menu-icon"></div>
  <ul class="navbar">
    <li><a href="/#home">Inicio</a></li>
    <li><a href="/#services">Servicios</a></li>
    <li><a href="/#about">Acerca de Nosotros</a></li>
    <li><a href="/#plans">Suscripciones</a></li>
    <li><a href="/products">Productos</a></li>
  </ul>
  <a class="nav-cart" href="/checkout/cart" aria-label="Carrito de compras">
    <i class="bx bx-cart" id="cart-icon"></i>
    <span class="cart-count" id="cart-count">0</span>
  </a>
  <div class="top-btn">
    {user ? (
      <>
        {user.role === "administrador" && <a href="/admin" class="username-link">Admin</a>}
        <a href="/profile" class="username-link"><i class="bx bx-user"></i><span>{user.username}</span></a>
        <form method="POST" action="/api/auth/logout"><button class="nav-btn">Cerrar Sesión</button></form>
      </>
    ) : <a href="/login" class="nav-btn">Iniciar Sesión</a>}
  </div>
</header>
<script is:inline data-script="fit360-header-cart-sync">
  (() => {
    const key = "fit360Cart";
    const readLocalCount = () => {
      try {
        const items = JSON.parse(localStorage.getItem(key) || "[]");
        return Array.isArray(items) ? items.reduce((total, item) => total + Number(item.quantity || item.cantidad || 0), 0) : 0;
      } catch {
        return 0;
      }
    };

    const paintCount = (count) => {
      document.querySelectorAll(".cart-count").forEach((node) => {
        node.textContent = String(count);
      });
    };

    const paintLocalCount = () => paintCount(readLocalCount());

    const syncRemoteCart = async () => {
      try {
        const response = await fetch("/api/cart");
        if (!response.ok) return;

        const remote = await response.json();
        if (!Array.isArray(remote) || !remote.length) {
          paintLocalCount();
          return;
        }

        const cart = remote.map((item) => ({
          id_producto: Number(item.id_producto),
          nombre: item.nombre,
          price: Number(item.precio),
          quantity: Number(item.cantidad),
          url_imagen: item.url_imagen
        }));

        localStorage.setItem(key, JSON.stringify(cart));
        paintCount(cart.reduce((total, item) => total + Number(item.quantity || 0), 0));
      } catch {
        paintLocalCount();
      }
    };

    paintLocalCount();
    syncRemoteCart();
    window.addEventListener("fit360-cart-updated", paintLocalCount);
    window.addEventListener("storage", (event) => {
      if (event.key === key) paintLocalCount();
    });
  })();
</script>
