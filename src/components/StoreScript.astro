<script>
  type CartItem={id_producto:number;nombre:string;price:number;quantity:number;url_imagen?:string};const key="fit360Cart";let cart:CartItem[]=JSON.parse(localStorage.getItem(key)||"[]");
  function updateCartCount(){const count=cart.reduce((total,item)=>total+Number(item.quantity||0),0);document.querySelectorAll(".cart-count").forEach((node)=>{node.textContent=String(count)})}
  async function persist(){localStorage.setItem(key,JSON.stringify(cart));updateCartCount();window.dispatchEvent(new Event("fit360-cart-updated"));await fetch("/api/cart",{method:"POST",headers:{"content-type":"application/json"},body:JSON.stringify({items:cart})}).catch(()=>{})}
  const syncRemoteCart=()=>fetch("/api/cart").then(r=>r.ok?r.json():[]).then((remote)=>{if(Array.isArray(remote)&&remote.length){cart=remote.map(i=>({id_producto:Number(i.id_producto),nombre:i.nombre,price:Number(i.precio),quantity:Number(i.cantidad),url_imagen:i.url_imagen}));localStorage.setItem(key,JSON.stringify(cart));updateCartCount();window.dispatchEvent(new Event("fit360-cart-updated"))}}).catch(()=>{});
  const scheduleRemoteCartSync=()=>{"requestIdleCallback" in window?window.requestIdleCallback(syncRemoteCart,{timeout:1500}):globalThis.setTimeout(syncRemoteCart,500)};
  updateCartCount();
  scheduleRemoteCartSync();
  document.querySelectorAll("[data-add-cart]").forEach(button=>button.addEventListener("click",()=>{const card=button.closest<HTMLElement>("[data-product]");if(!card?.dataset.product)return;const product=JSON.parse(card.dataset.product);const available=Number(product.cantidad_stock||0)-Number(product.stock_reservado||0);const item=cart.find(entry=>entry.id_producto===product.id_producto);if(item)item.quantity=Math.min(item.quantity+1,available);else if(available>0)cart.push({id_producto:product.id_producto,nombre:product.nombre,price:Number(product.precio),quantity:1,url_imagen:product.url_imagen});persist();button.textContent="Agregado";setTimeout(()=>button.textContent="Agregar al Carrito",900)}));
</script>
