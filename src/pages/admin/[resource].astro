---
import AdminLayout from "@/components/AdminLayout.astro"; import { resources } from "@/lib/admin"; import { rows } from "@/lib/db";
const name=Astro.params.resource as keyof typeof resources;const config=resources[name];if(!config)return Astro.redirect("/admin");const records=await rows<any>(config.list);const editId=Number(Astro.url.searchParams.get("edit")||0);const record=records.find((r)=>Number(r[config.id])===editId);
---
<AdminLayout title={config.title}><div class="admin-form"><h2>{record?"Editar":"Agregar"} registro</h2><form method="POST" action="/api/admin/resource"><input type="hidden" name="resource" value={name}/><input type="hidden" name="id" value={record?.[config.id]||""}/><div class="form-grid">{config.fields.map((field)=><div class="form-group"><label>{field.replaceAll("_"," ")}</label>{field.includes("descripcion")||field==="beneficios"||field==="direccion"?<textarea name={field} required>{record?.[field]??""}</textarea>:field==="esta_activo"||field==="es_destacado"?<select name={field}><option value="1" selected={record?.[field]!==0}>Sí</option><option value="0" selected={record?.[field]===0}>No</option></select>:<input name={field} value={record?.[field]??""} required={!["precio_anterior","telefono","apellido","id_categoria","url_imagen","url_video"].includes(field)} />}</div>)}</div><button class="btn">{record?"Actualizar":"Crear"}</button></form></div><div class="admin-table"><table><thead><tr>{Object.keys(records[0]||{}).map((key)=><th>{key}</th>)}<th>Acciones</th></tr></thead><tbody>{records.map((item)=><tr>{Object.values(item).map((value)=><td>{String(value??"").slice(0,80)}</td>)}<td><a class="btn btn-secondary" href={`/admin/${name}?edit=${item[config.id]}`}>Editar</a><form method="POST" action="/api/admin/resource"><input type="hidden" name="resource" value={name}/><input type="hidden" name="id" value={item[config.id]}/><input type="hidden" name="action" value="delete"/><button class="btn" onclick="return confirm('¿Confirmas la eliminación?')">Eliminar</button></form></td></tr>)}</tbody></table></div></AdminLayout>
