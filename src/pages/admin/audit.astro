---
import AdminLayout from "@/components/AdminLayout.astro";import { rows } from "@/lib/db";const logs=await rows<any>("SELECT a.*,u.nombre_usuario actor FROM audit_log a LEFT JOIN usuario u ON u.id_usuario=a.id_usuario_actor ORDER BY a.fecha_creacion DESC LIMIT 250");
---
<AdminLayout title="Auditoría"><div class="admin-table"><table><thead><tr><th>Fecha</th><th>Actor</th><th>Acción</th><th>Entidad</th><th>ID</th><th>IP</th></tr></thead><tbody>{logs.map(log=><tr><td>{log.fecha_creacion}</td><td>{log.actor||"Sistema"}</td><td>{log.accion}</td><td>{log.entidad}</td><td>{log.entidad_id}</td><td>{log.ip_address||"-"}</td></tr>)}</tbody></table></div></AdminLayout>
