---
import AdminLayout from "@/components/AdminLayout.astro";
import { row, rows } from "@/lib/db";
import { money } from "@/lib/format";

const stats = {
  users: await row<any>("SELECT COUNT(*) total FROM usuario"),
  subscriptions: await row<any>("SELECT COUNT(*) total FROM suscripcion_usuario WHERE estado='activa' AND date(fecha_fin)>=date('now')"),
  sales: await row<any>("SELECT COUNT(*) total FROM pago WHERE estado='completado'"),
  revenue: await row<any>("SELECT COALESCE(SUM(monto),0) total FROM pago WHERE estado='completado'"),
  products: await row<any>("SELECT COUNT(*) total FROM producto WHERE esta_activo=1"),
  services: await row<any>("SELECT COUNT(*) total FROM servicio WHERE esta_activo=1"),
  pendingOrders: await row<any>("SELECT COUNT(*) total FROM pedido WHERE estado='pendiente'"),
  lowStock: await row<any>("SELECT COUNT(*) total FROM producto WHERE esta_activo=1 AND cantidad_stock-stock_reservado<=umbral_stock_bajo"),
};
const revenueTrend = await rows<any>("SELECT strftime('%Y-%m',fecha_pago) month, COALESCE(SUM(monto),0) revenue, COUNT(*) sales FROM pago WHERE estado='completado' AND datetime(fecha_pago)>=datetime('now','-6 months') GROUP BY month ORDER BY month");
const recent = await rows<any>("SELECT nombre_usuario username,fecha_creacion date,'Nuevo usuario registrado' action FROM usuario ORDER BY fecha_creacion DESC LIMIT 8");
const lowStockProducts = await rows<any>("SELECT sku,nombre,cantidad_stock-stock_reservado disponible,umbral_stock_bajo FROM producto WHERE esta_activo=1 ORDER BY disponible ASC LIMIT 6");
const maxRevenue = Math.max(1, ...revenueTrend.map((item) => Number(item.revenue || 0)));
---
<AdminLayout title="Panel de Administración">
  <section class="admin-command-panel">
    <div>
      <p class="admin-kicker">Estado operativo</p>
      <h2>Control de tienda, membresías e inventario</h2>
    </div>
    <div class="admin-command-actions">
      <a class="btn" href="/admin/products?create=1"><i class="bx bx-plus"></i> Producto</a>
      <a class="btn btn-secondary" href="/admin/inventory"><i class="bx bx-package"></i> Inventario</a>
    </div>
  </section>

  <div class="stats-grid">
    <article class="stat-card"><i class="bx bxs-user-detail"></i><span>Usuarios</span><strong>{stats.users.total}</strong><small>Cuentas registradas</small></article>
    <article class="stat-card"><i class="bx bxs-badge-check"></i><span>Activas</span><strong>{stats.subscriptions.total}</strong><small>Suscripciones vigentes</small></article>
    <article class="stat-card"><i class="bx bxs-receipt"></i><span>Ventas</span><strong>{stats.sales.total}</strong><small>Pagos completados</small></article>
    <article class="stat-card stat-card-accent"><i class="bx bx-money-withdraw"></i><span>Ingresos</span><strong>{money(stats.revenue.total)}</strong><small>MXN confirmados</small></article>
    <article class="stat-card"><i class="bx bxs-shopping-bag"></i><span>Productos</span><strong>{stats.products.total}</strong><small>Activos en catálogo</small></article>
    <article class="stat-card"><i class="bx bx-error-circle"></i><span>Alertas</span><strong>{stats.lowStock.total}</strong><small>Productos con stock bajo</small></article>
  </div>

  <section class="admin-dashboard-grid">
    <article class="admin-panel chart-panel">
      <div class="panel-heading"><div><p class="admin-kicker">Ingresos</p><h2>Últimos 6 meses</h2></div><span>{money(stats.revenue.total)}</span></div>
      <div class="bar-chart" aria-label="Ingresos por mes">
        {revenueTrend.length ? revenueTrend.map((item) => {
          const value = Number(item.revenue || 0);
          const pct = Math.max(6, Math.round((value / maxRevenue) * 100));
          return <div class="bar-column" style={"--bar:" + pct + "%"}><span>{money(value)}</span><i></i><small>{item.month}</small></div>;
        }) : <p class="admin-empty">Sin ingresos registrados.</p>}
      </div>
    </article>

    <article class="admin-panel risk-panel">
      <div class="panel-heading"><div><p class="admin-kicker">Inventario</p><h2>Prioridad de reposición</h2></div><span>{stats.lowStock.total} alertas</span></div>
      <div class="stock-watch-list">
        {lowStockProducts.map((product) => <a href="/admin/inventory"><strong>{product.nombre}</strong><span>{product.sku || "Sin SKU"}</span><em>{product.disponible} disp. / mínimo {product.umbral_stock_bajo}</em></a>)}
      </div>
    </article>
  </section>

  <div class="admin-table">
    <div class="admin-table-heading"><div><p class="admin-kicker">Actividad</p><h2>Actividad reciente</h2></div></div>
    <div class="admin-table-inner" tabindex="0">
      <table>
        <thead><tr><th>Usuario</th><th>Actividad</th><th>Fecha</th></tr></thead>
        <tbody>{recent.map((item) => <tr><td data-label="Usuario">{item.username}</td><td data-label="Actividad">{item.action}</td><td data-label="Fecha">{item.date}</td></tr>)}</tbody>
      </table>
    </div>
  </div>
</AdminLayout>
