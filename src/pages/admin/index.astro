---
import AdminLayout from "@/components/AdminLayout.astro"; import { row,rows } from "@/lib/db"; import { money } from "@/lib/format";
const stats={users:await row<any>("SELECT COUNT(*) total FROM usuario"),subscriptions:await row<any>("SELECT COUNT(*) total FROM suscripcion_usuario WHERE estado='activa' AND date(fecha_fin)>=date('now')"),sales:await row<any>("SELECT COUNT(*) total FROM pago WHERE estado='completado'"),revenue:await row<any>("SELECT COALESCE(SUM(monto),0) total FROM pago WHERE estado='completado'"),products:await row<any>("SELECT COUNT(*) total FROM producto WHERE esta_activo=1"),services:await row<any>("SELECT COUNT(*) total FROM servicio WHERE esta_activo=1")};const recent=await rows<any>("SELECT nombre_usuario username,fecha_creacion date,'Nuevo usuario registrado' action FROM usuario ORDER BY fecha_creacion DESC LIMIT 8");
---
<AdminLayout title="Panel de Administración"><div class="stats-grid"><div class="stat-card"><h3>Usuarios</h3><p>{stats.users.total}</p></div><div class="stat-card"><h3>Suscripciones activas</h3><p>{stats.subscriptions.total}</p></div><div class="stat-card"><h3>Ventas</h3><p>{stats.sales.total}</p></div><div class="stat-card"><h3>Ingresos</h3><p>{money(stats.revenue.total)}</p></div><div class="stat-card"><h3>Productos</h3><p>{stats.products.total}</p></div><div class="stat-card"><h3>Servicios</h3><p>{stats.services.total}</p></div></div><div class="admin-table"><h2>Actividad reciente</h2><table><thead><tr><th>Usuario</th><th>Actividad</th><th>Fecha</th></tr></thead><tbody>{recent.map((item)=><tr><td>{item.username}</td><td>{item.action}</td><td>{item.date}</td></tr>)}</tbody></table></div></AdminLayout>
