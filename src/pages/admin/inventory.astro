---
import AdminLayout from "@/components/AdminLayout.astro";import { rows } from "@/lib/db";
const products=await rows<any>("SELECT id_producto,sku,nombre,cantidad_stock,stock_reservado,umbral_stock_bajo,cantidad_stock-stock_reservado disponible FROM producto WHERE esta_activo=1 ORDER BY disponible ASC");const movements=await rows<any>("SELECT m.*,p.nombre producto FROM movimiento_inventario m JOIN producto p ON p.id_producto=m.id_producto ORDER BY m.fecha_creacion DESC LIMIT 100");
---
<AdminLayout title="Inventario"><div class="admin-form"><h2>Ajustar inventario</h2><form method="POST" action="/api/admin/inventory"><select name="productId" required>{products.map(p=><option value={p.id_producto}>{p.nombre}</option>)}</select><input type="number" name="quantity" required placeholder="Cantidad positiva o negativa"/><input name="note" required placeholder="Motivo del ajuste"/><button class="btn">Aplicar ajuste</button></form></div><div class="admin-table"><h2>Existencias</h2><table><thead><tr><th>SKU</th><th>Producto</th><th>Stock</th><th>Reservado</th><th>Disponible</th><th>Alerta</th></tr></thead><tbody>{products.map(p=><tr><td>{p.sku||"-"}</td><td>{p.nombre}</td><td>{p.cantidad_stock}</td><td>{p.stock_reservado}</td><td>{p.disponible}</td><td>{p.disponible<=p.umbral_stock_bajo?"Stock bajo":"OK"}</td></tr>)}</tbody></table></div><div class="admin-table"><h2>Movimientos recientes</h2><table><thead><tr><th>Producto</th><th>Tipo</th><th>Cantidad</th><th>Antes</th><th>Después</th><th>Fecha</th></tr></thead><tbody>{movements.map(m=><tr><td>{m.producto}</td><td>{m.tipo}</td><td>{m.cantidad}</td><td>{m.stock_anterior}</td><td>{m.stock_nuevo}</td><td>{m.fecha_creacion}</td></tr>)}</tbody></table></div></AdminLayout>
