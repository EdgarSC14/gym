---
import { readdir, stat } from "node:fs/promises"; import { join } from "node:path"; import AdminLayout from "@/components/AdminLayout.astro";
const root=join(process.cwd(),"public","assets");const groups=["products","services","videos"];const files=(await Promise.all(groups.map(async(group)=>Promise.all((await readdir(join(root,group))).map(async(name)=>({group,name,size:(await stat(join(root,group,name))).size})))))).flat();
---
<AdminLayout title="Gestión de Multimedia"><div class="admin-form"><h2>Subir archivos</h2><form method="POST" action="/api/admin/media" enctype="multipart/form-data"><select name="group" required>{groups.map((group)=><option value={group}>{group}</option>)}</select><input type="file" name="files" multiple required/><button class="btn">Subir</button></form></div><div class="admin-table"><table><thead><tr><th>Tipo</th><th>Archivo</th><th>Tamaño</th><th>Acción</th></tr></thead><tbody>{files.map((file)=><tr><td>{file.group}</td><td>/assets/{file.group}/{file.name}</td><td>{Math.round(file.size/1024)} KB</td><td><form method="POST" action="/api/admin/media"><input type="hidden" name="path" value={`${file.group}/${file.name}`}/><input type="hidden" name="action" value="delete"/><button class="btn">Eliminar</button></form></td></tr>)}</tbody></table></div></AdminLayout>
