---
import Layout from "@/components/Layout.astro"; import Header from "@/components/Header.astro"; import Footer from "@/components/Footer.astro";
---
<Layout title="Iniciar sesión | Fit 360" description="Accede a tu cuenta Fit 360 para gestionar tu perfil, carrito, suscripciones y compras." canonicalPath="/login" noindex><Header /><section class="auth-section"><div class="auth-container"><div class="auth-content"><h2>Iniciar Sesión</h2>{Astro.url.searchParams.get("error") && <div class="error-message">{Astro.url.searchParams.get("error")}</div>}<form class="auth-form" method="POST" action="/api/auth/login"><div class="form-group"><label>Correo Electrónico</label><div class="input-group"><i class="bx bx-envelope"></i><input type="email" name="email" required /></div></div><div class="form-group"><label>Contraseña</label><div class="input-group"><i class="bx bx-lock-alt"></i><input type="password" name="password" minlength="8" required /></div></div><button type="submit" class="btn">Acceder</button><div class="auth-links"><a href="/register">¿No tienes cuenta? Regístrate</a></div></form></div></div></section><Footer /></Layout>
