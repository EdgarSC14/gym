---
import Layout from "@/components/Layout.astro"; import Header from "@/components/Header.astro"; import Footer from "@/components/Footer.astro";
---
<Layout title="Crear cuenta | Fit 360" description="Crea una cuenta Fit 360 para guardar tu carrito, gestionar suscripciones y publicar reseñas." canonicalPath="/register" noindex><Header /><section class="auth-section"><div class="auth-container"><div class="auth-content"><h2>Crear Cuenta</h2>{Astro.url.searchParams.get("error") && <div class="error-message">{Astro.url.searchParams.get("error")}</div>}<form class="auth-form" method="POST" action="/api/auth/register"><div class="form-group"><label>Nombre de Usuario *</label><input name="username" minlength="3" pattern="[A-Za-z0-9_]+" required /></div><div class="form-group"><label>Nombre *</label><input name="first_name" pattern="[A-Za-zÁÉÍÓÚáéíóúÑñ ]+" required /></div><div class="form-group"><label>Apellido</label><input name="last_name" pattern="[A-Za-zÁÉÍÓÚáéíóúÑñ ]+" /></div><div class="form-group"><label>Correo Electrónico *</label><input type="email" name="email" required /></div><div class="form-group"><label>Contraseña *</label><input type="password" name="password" minlength="10" required /></div><div class="form-group"><label>Confirmar Contraseña *</label><input type="password" name="confirm_password" minlength="10" required /></div><button class="btn">Registrarse</button><div class="auth-links"><a href="/login">¿Ya tienes cuenta? Inicia Sesión</a></div></form></div></div></section><Footer /></Layout>
